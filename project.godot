; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=4

_global_script_classes=[ {
"base": "Node2D",
"class": "Actor",
"language": "GDScript",
"path": "res://combat/actors/_key_components/Actor.gd"
}, {
"base": "Actor",
"class": "ActorEnemy",
"language": "GDScript",
"path": "res://combat/actors/_key_components/ActorEnemy.gd"
}, {
"base": "Actor",
"class": "ActorPlayer",
"language": "GDScript",
"path": "res://combat/actors/_key_components/ActorPlayer.gd"
}, {
"base": "Reference",
"class": "Array2D",
"language": "GDScript",
"path": "res://src/classes/_Array2D.gd"
}, {
"base": "PopupPanel",
"class": "EditorInputPopup",
"language": "GDScript",
"path": "res://addons/editor_tools/EditorInputPopup.gd"
}, {
"base": "Resource",
"class": "MoveAction",
"language": "GDScript",
"path": "res://src/classes/_MoveAction.gd"
}, {
"base": "HBoxContainer",
"class": "PipSet",
"language": "GDScript",
"path": "res://combat/battle_ui/_archive/PipSet.gd"
}, {
"base": "NinePatchRect",
"class": "Sprite9Patch",
"language": "GDScript",
"path": "res://src/classes/_Sprite9Patch.gd"
}, {
"base": "Node",
"class": "YPing",
"language": "GDScript",
"path": "res://src/classes/_YPing.gd"
}, {
"base": "Timer",
"class": "YTimer",
"language": "GDScript",
"path": "res://src/classes/_YTimer.gd"
} ]
_global_script_class_icons={
"Actor": "",
"ActorEnemy": "",
"ActorPlayer": "",
"Array2D": "",
"EditorInputPopup": "",
"MoveAction": "",
"PipSet": "",
"Sprite9Patch": "",
"YPing": "",
"YTimer": ""
}

[application]

config/name="Strata-G"
run/main_scene="res://src/masters/GameRoot.tscn"
boot_splash/bg_color=Color( 0, 0, 0, 1 )
config/icon="res://art/bui/aimflowers/3x3 - plus.png"

[autoload]

loader="*res://src/masters/__Loader.gd"
data="*res://src/masters/__Data.gd"
utils="*res://src/masters/__Utils.gd"
support="*res://src/masters/__SupportLib.gd"
batman="*res://src/masters/__BattleMgr.gd"
controls="*res://src/masters/__Controls.gd"
strife="*res://src/masters/__Strife.gd"

[debug]

settings/fps/force_fps=60
gdscript/warnings/unassigned_variable=false
gdscript/warnings/narrowing_conversion=false
gdscript/warnings/unused_signal=false
gdscript/warnings/return_value_discarded=false
gdscript/warnings/integer_division=false

[display]

window/size/width=640
window/size/height=360
window/size/resizable=false
window/size/test_width=1280
window/size/test_height=720
window/stretch/mode="viewport"
window/stretch/aspect="keep"

[editor]

search_in_file_extensions=PoolStringArray( "gd", "gdshader", "tscn", "tres" )

[editor_plugins]

enabled=PoolStringArray( "res://addons/editor_tools/plugin.cfg" )

[importer_defaults]

texture={
"compress/bptc_ldr": 0,
"compress/hdr_mode": 0,
"compress/lossy_quality": 0.7,
"compress/mode": 0,
"compress/normal_map": 0,
"detect_3d": true,
"flags/anisotropic": false,
"flags/filter": false,
"flags/mipmaps": false,
"flags/repeat": 0,
"flags/srgb": 2,
"process/HDR_as_SRGB": false,
"process/fix_alpha_border": true,
"process/invert_color": false,
"process/normal_map_invert_y": false,
"process/premult_alpha": false,
"size_limit": 0,
"stream": false,
"svg/scale": 1.0
}

